# =============================================================================
# ONLYFANS PROD — Environment variables template
# Copy to .env and fill in the values.
# Get Supabase connection strings: Dashboard → Settings → Database → Connect
# =============================================================================

# --- Database (Supabase Postgres) — REQUIRED ---
# Transaction pooler (serverless) — use from Dashboard → Connect → Transaction
POSTGRES_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-DB-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (migrations, triggers) — use from Dashboard → Connect → Direct
POSTGRES_URL_NON_POOLING=postgresql://postgres:[YOUR-DB-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Optional: Prisma runtime URL. If unset, falls back to POSTGRES_URL
# POSTGRES_PRISMA_URL=

# --- Supabase (Auth + Storage) — REQUIRED ---
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt_key
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt_key

# --- NextAuth (Google) — REQUIRED for login ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# --- OnlyFans API — REQUIRED for creators/inbox ---
OFAPI_API_KEY=your_ofapi_key
OFAPI_WEBHOOK_SECRET=your_webhook_secret

# --- AI APIs ---
OPENAI_API_KEY=your_openai_key
MOONSHOT_API_KEY=your_moonshot_key
# KIMI_API_KEY=alternative_to_moonshot
# GEMINI_API_KEY=only_if_using_ai-analyzer

# --- Cron / Vercel (production) ---
CRON_SECRET=random_secret_for_cron_routes

# --- Optional integrations ---
# TELEGRAM_BOT_TOKEN=
# SYNC_SECRET=
# UPLOAD_LINK_SECRET=
# HUBSTAFF_REFRESH_TOKEN=
# HUBSTAFF_ORG_ID=
# NEXT_PUBLIC_APP_URL=https://onlyfans-prod.vercel.app
